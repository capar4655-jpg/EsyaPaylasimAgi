rules_version = '2';

// CircularShare / Eşya Paylaşım Ağı – Firestore güvenlik kuralları
// Bu kuralları Firebase Console > Firestore Database > Kurallar (Rules) sekmesine
// yapıştırıp "Yayınla" diyebilirsin. (Geliştirme sırasında "test modu" da kullanılabilir.)

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    // Kullanıcı profilleri
    // Not: İade tamamlandığında karşı tarafın eco-puanı da güncellendiği için
    // update giriş yapmış tüm kullanıcılara açıktır (sınıf projesi için yeterli).
    match /users/{userId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.auth.uid == userId;
      allow update: if signedIn();
    }

    // Eşyalar
    match /items/{itemId} {
      allow read: if signedIn();
      allow create: if signedIn()
                    && request.resource.data.ownerId == request.auth.uid;
      allow update: if signedIn();
      allow delete: if signedIn()
                    && resource.data.ownerId == request.auth.uid;
    }

    // Talepler (ödünç istekleri)
    match /requests/{requestId} {
      allow read, create, update: if signedIn();
    }

    // Sohbetler ve mesajlar
    match /chats/{chatId} {
      allow read, create, update: if signedIn();
      match /messages/{messageId} {
        allow read, create: if signedIn();
      }
    }
  }
}
